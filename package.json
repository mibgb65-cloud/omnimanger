{
  "name": "account-secret-vault",
  "version": "0.1.0",
  "description": "A client-side encrypted account secret vault for Cloudflare Workers and KV.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "check": "node scripts/check.mjs && node --test",
    "test": "node --test",
    "e2e": "python -m unittest discover -s e2e -p \"*.py\"",
    "predeploy": "npm run check && npm run e2e",
    "dev": "wrangler dev --local --port 8787",
    "deploy:dry-run": "npm run predeploy && wrangler deploy --dry-run",
    "deploy": "wrangler deploy"
  }
}
